####################################
# App
####################################
NODE_ENV=production
PORT=3000

####################################
# Database (PostgreSQL)
####################################
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=cyberphone

DATABASE_HOST=postgresql
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=password
DATABASE_NAME=cyberphone

####################################
# Auth
####################################
JWT_ACCESS_SECRET=random-64-char-string
JWT_REFRESH_SECRET=another-random-64-char-string

ACCESS_TOKEN_TTL=900        # 15 minutes
REFRESH_TOKEN_TTL=2592000   # 30 days

COOKIE_DOMAIN=yourdomain.com

####################################
# CORS
####################################
# Comma-separated list of allowed frontend origins
CORS_ORIGINS=https://yourdomain.com

####################################
# Super Admin Seed
####################################
SUPER_ADMIN_PHONE=0987654321
SUPER_ADMIN_EMAIL=admin@yourdomain.com
SUPER_ADMIN_PASSWORD=admin-password
SUPER_ADMIN_FIRST_NAME=Admin
SUPER_ADMIN_LAST_NAME=User

####################################
# Cloudinary (media storage)
####################################
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
CLOUDINARY_ROOT_FOLDER=cyberphone

####################################
# Email (SMTP)
####################################
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM="CyberPhone <noreply@yourdomain.com>"

####################################
# MoMo Payment
####################################
MOMO_PARTNER_CODE=your-partner-code
MOMO_ACCESS_KEY=your-access-key
MOMO_SECRET_KEY=your-secret-key
MOMO_API_ENDPOINT=https://payment.momo.vn/v2/gateway/api/create
MOMO_REDIRECT_URL=https://yourdomain.com/checkout/result
MOMO_IPN_URL=https://api.yourdomain.com/api/payment/momo/webhook
MOMO_STORE_ID=CyberPhone
MOMO_SANDBOX=false
